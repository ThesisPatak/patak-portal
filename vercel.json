{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "status": 308,
      "headers": {
        "Location": "https://patak-portal-production-47ad.up.railway.app/$1"
      }
    }
  ],
  "env": {
    "VITE_API_URL": "https://patak-portal-production-47ad.up.railway.app",
    "REACT_APP_API_URL": "https://patak-portal-production-47ad.up.railway.app"
  }
}
